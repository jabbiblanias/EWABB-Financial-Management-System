<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Loan Form</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-100 flex items-center justify-center min-h-screen">
    <div class="bg-white rounded-xl shadow-md p-8 w-96">
      <!-- Loan Type -->
      <div class="mb-4">
        <label class="block text-gray-700 mb-1">Loan Type</label>
        <select
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 text-gray-500"
        >
          <option selected disabled>Choose Loan Type</option>
          <option>Personal Loan</option>
          <option>Business Loan</option>
          <option>Emergency Loan</option>
        </select>
      </div>

      <!-- Amount -->
      <div class="mb-4">
        <label class="block text-gray-700 mb-1">Amount</label>
        <input
          type="number"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
      </div>

      <!-- Term -->
      <div class="mb-6">
        <label class="block text-gray-700 mb-1">Term</label>
        <input type="range" min="1" max="5" value="1" class="w-full accent-blue-600" />
        <p class="text-center text-black mt-1">1 Year</p>
      </div>

      <!-- Details -->
      <div class="space-y-2 mb-6">
        <div class="flex justify-between text-gray-700">
          <span>Service Charge</span>
          <span class="text-black font-medium">2%</span>
        </div>
        <div class="flex justify-between text-gray-700">
          <span>Release Amount</span>
          <span class="text-black font-medium">12,000</span>
        </div>
        <div class="flex justify-between text-gray-700">
          <span>Installment</span>
          <span class="text-black font-medium">800 / Monthly</span>
        </div>
      </div>

      <!-- Buttons -->
      <div class="flex justify-between items-center">
        <button class="text-black font-medium">Clear</button>
        <button
          class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2 rounded-lg"
        >
          Submit
        </button>
      </div>
    </div>
  </body>
</html>
